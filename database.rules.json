{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$roomCode": {
        "control": {
          ".read": "auth != null",
          ".write": "auth != null && ((!data.exists() && newData.child('hostUid').val() === auth.uid) || data.child('hostUid').val() === auth.uid)"
        },
        "participants": {
          "$playerId": {
            ".read": "auth != null && (data.child('uid').val() === auth.uid || root.child('rooms').child($roomCode).child('control').child('hostUid').val() === auth.uid)",
            ".write": "auth != null && ((!data.exists() && newData.child('uid').val() === auth.uid) || data.child('uid').val() === auth.uid || root.child('rooms').child($roomCode).child('control').child('hostUid').val() === auth.uid)"
          }
        },
        "presence": {
          ".read": "auth != null",
          "$playerId": {
            ".write": "auth != null && root.child('rooms').child($roomCode).child('participants').child($playerId).child('uid').val() === auth.uid && newData.child('authUid').val() === auth.uid"
          }
        },
        "snapshots": {
          "$snapshotId": {
            "public": {
              ".read": "auth != null",
              ".write": "auth != null && root.child('rooms').child($roomCode).child('control').child('hostUid').val() === auth.uid"
            },
            "private": {
              "$playerId": {
                ".read": "auth != null && root.child('rooms').child($roomCode).child('participants').child($playerId).child('uid').val() === auth.uid",
                ".write": "auth != null && root.child('rooms').child($roomCode).child('control').child('hostUid').val() === auth.uid"
              }
            }
          }
        },
        "resyncRequests": {
          "$requestId": {
            ".read": "auth != null && (root.child('rooms').child($roomCode).child('control').child('hostUid').val() === auth.uid || root.child('rooms').child($roomCode).child('participants').child(data.child('playerId').val()).child('uid').val() === auth.uid)",
            ".write": "auth != null && (root.child('rooms').child($roomCode).child('control').child('hostUid').val() === auth.uid || root.child('rooms').child($roomCode).child('participants').child(newData.child('playerId').val()).child('uid').val() === auth.uid)"
          }
        },
        "messages": {
          ".read": "auth != null",
          "$messageId": {
            ".write": "auth != null"
          }
        },
        "peers": {
          ".read": "auth != null",
          "$peerId": {
            ".write": "auth != null"
          }
        },
        "lobby": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('control').child('hostUid').val() === auth.uid"
        },
        "game": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('control').child('hostUid').val() === auth.uid"
        }
      }
    },
    "watchRooms": {
      "$watchRoomCode": {
        ".read": false,
        ".write": false,
        "control": {
          ".read": "auth != null",
          ".write": "auth != null && ((!data.exists() && newData.child('hostUid').val() === auth.uid && newData.child('watchRoomCode').val() === $watchRoomCode) || data.child('hostUid').val() === auth.uid)",
          ".validate": "newData.hasChildren(['watchRoomCode','hostUid','replayId','replayTitle','createdAt','updatedAt','expiresAt','playback']) && !newData.hasChild('replayFile') && !newData.hasChild('initialGameState') && !newData.hasChild('finalGameState') && !newData.hasChild('actionLog') && !newData.hasChild('cards') && !newData.hasChild('definitions')"
        },
        "viewers": {
          ".read": "auth != null",
          "$viewerId": {
            ".write": "auth != null && $viewerId === auth.uid && newData.child('viewerId').val() === auth.uid"
          }
        },
        "comments": {
          ".read": "auth != null && (root.child('watchRooms').child($watchRoomCode).child('viewers').child(auth.uid).exists() || root.child('watchRooms').child($watchRoomCode).child('control').child('hostUid').val() === auth.uid)",
          "$commentId": {
            ".write": "auth != null && newData.child('viewerId').val() === auth.uid",
            ".validate": "newData.hasChildren(['commentId','watchRoomCode','actionIndex','viewerId','displayName','createdAt','body','type']) && newData.child('commentId').val() === $commentId && newData.child('watchRoomCode').val() === $watchRoomCode && newData.child('actionIndex').isNumber() && newData.child('body').isString() && (newData.child('type').val() === 'comment' || newData.child('type').val() === 'question' || newData.child('type').val() === 'reaction') && !newData.hasChild('replayFile') && !newData.hasChild('initialGameState') && !newData.hasChild('finalGameState') && !newData.hasChild('actionLog') && !newData.hasChild('cards') && !newData.hasChild('definitions')"
          }
        }
      }
    },
    "reports": {
      ".read": false,
      ".indexOn": ["createdAt", "expiresAt", "status", "fingerprint", "clusterId"],
      "$reportId": {
        ".write": "auth != null && !data.exists() && newData.exists() && newData.child('reportId').val() === $reportId && newData.child('privacyMode').val() !== 'local_export_only'"
      }
    },
    "reportClusters": {
      ".read": false,
      ".indexOn": ["lastSeenAt", "expiresAt", "status", "fingerprint"],
      "$clusterId": {
        ".write": "auth != null && newData.exists() && newData.child('clusterId').val() === $clusterId"
      }
    },
    "reportCleanupLog": {
      ".read": false,
      "$cleanupRunId": {
        ".write": "auth != null && newData.exists()"
      }
    }
  }
}
