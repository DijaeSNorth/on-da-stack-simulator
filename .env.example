# Local environment defaults for local development
VITE_ENABLE_FIREBASE_FALLBACK=false
VITE_FIREBASE_RTDB_URL=https://your-project-id-default-rtdb.firebaseio.com
# VITE_FIREBASE_DATABASE_URL= # Alternate key name supported by code

# Firebase Realtime Database multiplayer recovery layer
# Frontend config only. Do not add service-account credentials here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
